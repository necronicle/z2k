#!/bin/sh
# /opt/etc/init.d/S99zapret2
# ��������� ������������ init.d/openwrt/zapret2 ��� Keenetic
# ���������� ������ common/ � config ���� ������ hardcoded ��������

# ==============================================================================
# ���� � ����������
# ==============================================================================

ZAPRET_BASE=/opt/zapret2
ZAPRET_RW=${ZAPRET_RW:-"$ZAPRET_BASE"}
ZAPRET_CONFIG=${ZAPRET_CONFIG:-"$ZAPRET_RW/config"}

# �������� ��� zapret2 ����������
[ -d "$ZAPRET_BASE" ] || {
    echo "ERROR: zapret2 not installed in $ZAPRET_BASE"
    exit 1
}

# ==============================================================================
# SOURCE ����������� ������� (��� � init.d/openwrt/functions)
# ==============================================================================

# ������� �������
. "$ZAPRET_BASE/common/base.sh"

# ����������� ���� firewall (iptables/nftables)
. "$ZAPRET_BASE/common/fwtype.sh"

# KEENETIC FIX: �������������� linux_ipt_avail ��� ������ ��� ip6tables
# �� Keenetic ����� ���� DISABLE_IPV6=1, �� iptables ��� ����� ��������
linux_ipt_avail()
{
	# ��� Keenetic ���������� ������ iptables (IPv4-only �����)
	[ -n "$Z2K_DEBUG" ] && echo "DEBUG: linux_ipt_avail() �������"
	exists iptables
	local result=$?
	[ -n "$Z2K_DEBUG" ] && echo "DEBUG: exists iptables = $result"
	return $result
}

# IP helper functions
. "$ZAPRET_BASE/common/linux_iphelper.sh"

# ������� ��� ������ � iptables
. "$ZAPRET_BASE/common/ipt.sh"

# ������� ��� ������ � nftables (���� ��������)
existf zapret_do_firewall_nft || . "$ZAPRET_BASE/common/nft.sh" 2>/dev/null

# ���������� firewall
. "$ZAPRET_BASE/common/linux_fw.sh"

# ���������� daemon ����������
. "$ZAPRET_BASE/common/linux_daemons.sh"

# ������ �� �������� �������
. "$ZAPRET_BASE/common/list.sh"

# ��������� custom scripts
. "$ZAPRET_BASE/common/custom.sh"

# ==============================================================================
# �������� ������������
# ==============================================================================

# ��������� ������������
. "$ZAPRET_CONFIG"

# DEBUG: ��������� FWTYPE ����� �������� config
[ -n "$Z2K_DEBUG" ] && echo "DEBUG: ����� �������� config - FWTYPE='$FWTYPE'"

# ��������: ������������� ����� � ������ iptables (�������� - �� :)
# std_ports() ���� ������� ��� �������� ipt.sh, �� ����� ���������� ���� ������
# �������� ������� std_ports() ����� �������� config
command -v std_ports >/dev/null 2>&1 && std_ports
[ -n "$Z2K_DEBUG" ] && echo "DEBUG: std_ports() ������� - NFQWS2_PORTS_TCP_IPT='$NFQWS2_PORTS_TCP_IPT'"

# ------------------------------------------------------------------------------
# �������� ������ ��� ORCHESTRATION (STRICT MANUAL MODE)
# ------------------------------------------------------------------------------
# ��� ���������� ������ ������������� (��������, circular) ��������� ������
# �������� RST/redirect � �.�. ������� �������� �������� ������� �� ���������.
[ -z "$NFQWS2_TCP_PKT_IN" ] && NFQWS2_TCP_PKT_IN="$NFQWS2_TCP_PKT_OUT"
[ -z "$NFQWS2_UDP_PKT_IN" ] && NFQWS2_UDP_PKT_IN="$NFQWS2_UDP_PKT_OUT"

# ------------------------------------------------------------------------------
# AUTOHOSTLIST: ensure required files exist to avoid nfqws2 start failures
# ------------------------------------------------------------------------------
ensure_autohostlist_files()
{
	[ "$MODE_FILTER" = "autohostlist" ] || return 0
	local base="${HOSTLIST_BASE:-$ZAPRET_BASE/ipset}"
	mkdir -p "$base" || return 1
	local auto="$base/zapret-hosts-auto.txt"
	local debuglog="$base/zapret-hosts-auto-debug.log"
	[ -f "$auto" ] || : > "$auto"
	[ "$AUTOHOSTLIST_DEBUGLOG" = "1" ] && [ -f "$debuglog" ] || : > "$debuglog"

	# Populate iptables exclude list from z2k whitelist so nfqueue never sees them
	local whitelist="${AUTOHOSTLIST_WHITELIST:-$ZAPRET_BASE/lists/whitelist.txt}"
	local exclude_txt="$base/zapret-hosts-exclude.txt"
	[ -f "$whitelist" ] && cp -f "$whitelist" "$exclude_txt" 2>/dev/null || : > "$exclude_txt"
}

normalize_autohost_domains()
{
	# Normalize possible host/domain forms to bare lowercase domain names.
	awk '
	{
		s=$0
		gsub(/\r/, "", s)
		sub(/#.*/, "", s)
		gsub(/^[[:space:]]+|[[:space:]]+$/, "", s)
		if (s == "") next

		s=tolower(s)
		sub(/^[a-z][a-z0-9+.-]*:\/\//, "", s)
		sub(/\/.*/, "", s)
		sub(/:[0-9]+$/, "", s)
		gsub(/^\*\./, "", s)
		sub(/\.$/, "", s)
		gsub(/^[[:space:]]+|[[:space:]]+$/, "", s)
		if (s == "") next

		if (s ~ /[^a-z0-9.-]/) next
		if (s ~ /\.\./) next
		if (index(s, ".") == 0) next

		n=split(s, a, ".")
		if (n < 2) next
		bad=0
		for (i=1; i<=n; i++) {
			if (a[i] == "") { bad=1; break }
			if (a[i] ~ /^-/ || a[i] ~ /-$/) { bad=1; break }
			if (a[i] !~ /^[a-z0-9-]+$/) { bad=1; break }
		}
		if (bad) next
		print s
	}
	'
}

sync_autohostlist_to_rkn()
{
	[ "${AUTOHOSTLIST_SYNC_TO_RKN:-1}" = "1" ] || return 0

	local base="${HOSTLIST_BASE:-$ZAPRET_BASE/ipset}"
	local auto="${AUTOHOSTLIST_FILE:-$base/zapret-hosts-auto.txt}"
	local rkn_list="${AUTOHOSTLIST_RKN_LIST:-$ZAPRET_BASE/extra_strats/TCP/RKN/List.txt}"
	local whitelist="${AUTOHOSTLIST_WHITELIST:-$ZAPRET_BASE/lists/whitelist.txt}"

	[ -s "$auto" ] || return 0
	mkdir -p "$(dirname "$rkn_list")" 2>/dev/null || true
	[ -f "$rkn_list" ] || : > "$rkn_list"

	local tmp_auto tmp_have tmp_add tmp_final
	tmp_auto="$(mktemp /tmp/z2k_ah_auto.XXXXXX 2>/dev/null || echo "/tmp/z2k_ah_auto.$$")"
	tmp_have="$(mktemp /tmp/z2k_ah_have.XXXXXX 2>/dev/null || echo "/tmp/z2k_ah_have.$$")"
	tmp_add="$(mktemp /tmp/z2k_ah_add.XXXXXX 2>/dev/null || echo "/tmp/z2k_ah_add.$$")"
	tmp_final="$(mktemp /tmp/z2k_ah_final.XXXXXX 2>/dev/null || echo "/tmp/z2k_ah_final.$$")"

	normalize_autohost_domains < "$auto" | sort -u > "$tmp_auto" 2>/dev/null || true
	[ -s "$tmp_auto" ] || {
		rm -f "$tmp_auto" "$tmp_have" "$tmp_add" "$tmp_final" 2>/dev/null || true
		return 0
	}

	{
		[ -f "$rkn_list" ] && cat "$rkn_list"
		[ -f "$whitelist" ] && cat "$whitelist"
	} | normalize_autohost_domains | sort -u > "$tmp_have" 2>/dev/null || true

	awk 'NR==FNR { seen[$0]=1; next } !($0 in seen) { print }' "$tmp_have" "$tmp_auto" > "$tmp_add"
	local added
	added=$(awk 'END { print NR+0 }' "$tmp_add")

	if [ "$added" -gt 0 ]; then
		cat "$tmp_add" >> "$rkn_list"
		sort -u "$rkn_list" > "$tmp_final" 2>/dev/null && mv "$tmp_final" "$rkn_list"
		echo "autohostlist sync: added $added domains to $rkn_list"
		# Clear the auto list to prevent infinite growth and redundant reparsing
		: > "$auto"
	fi

	rm -f "$tmp_auto" "$tmp_have" "$tmp_add" "$tmp_final" 2>/dev/null || true
}

# ------------------------------------------------------------------------------
# AUTOCIRCULAR: ensure writable cache files for runtime user (WS_USER / nobody)
# ------------------------------------------------------------------------------
ensure_autocircular_files()
{
	local base="${EXTRA_STRATS_DIR:-$ZAPRET_BASE/extra_strats}/cache/autocircular"
	mkdir -p "$base" || return 1
	chmod 777 "$base" 2>/dev/null || true

	[ -f "$base/state.tsv" ] || : > "$base/state.tsv"
	chmod 666 "$base/state.tsv" 2>/dev/null || true

	[ -f "$base/debug.log" ] || : > "$base/debug.log"
	chmod 666 "$base/debug.log" 2>/dev/null || true

	# Optional debug toggle file; keep if present and readable.
	[ -f "$base/debug.flag" ] && chmod 666 "$base/debug.flag" 2>/dev/null || true
}

# ------------------------------------------------------------------------------
# TRAFFIC DEBUG: capture "real traffic" (tcpdump pcap) and "traffic in zapret" (nfqws2 --debug log)
# ------------------------------------------------------------------------------
Z2K_TRAFFIC_DEBUG=0
Z2K_TRAFFIC_DEBUG_BASE=""
Z2K_TRAFFIC_DEBUG_PIDFILE=""

ensure_traffic_debug_files()
{
	local base="${EXTRA_STRATS_DIR:-$ZAPRET_BASE/extra_strats}/cache/traffic"
	mkdir -p "$base" || return 1
	chmod 777 "$base" 2>/dev/null || true

	[ -f "$base/nfqws2.debug.log" ] || : > "$base/nfqws2.debug.log"
	chmod 666 "$base/nfqws2.debug.log" 2>/dev/null || true

	[ -f "$base/tcpdump.err.log" ] || : > "$base/tcpdump.err.log"
	chmod 666 "$base/tcpdump.err.log" 2>/dev/null || true

	# Optional toggle file; keep if present and readable.
	[ -f "$base/debug.flag" ] && chmod 666 "$base/debug.flag" 2>/dev/null || true
}

traffic_debug_prepare()
{
	local base="${EXTRA_STRATS_DIR:-$ZAPRET_BASE/extra_strats}/cache/traffic"
	Z2K_TRAFFIC_DEBUG_BASE="$base"
	Z2K_TRAFFIC_DEBUG_PIDFILE="$base/tcpdump.pid"

	if [ -f "$base/debug.flag" ]; then
		Z2K_TRAFFIC_DEBUG=1
	else
		Z2K_TRAFFIC_DEBUG=0
	fi
}

traffic_debug_enable_nfqws2_log()
{
	[ "$Z2K_TRAFFIC_DEBUG" = "1" ] || return 0

	# Avoid duplicating the option if start() is called twice in one script run.
	case " $NFQWS2_OPT_BASE " in
		*" --debug="*)
			return 0
			;;
	esac

	NFQWS2_OPT_BASE="$NFQWS2_OPT_BASE --debug=@$Z2K_TRAFFIC_DEBUG_BASE/nfqws2.debug.log"
}

traffic_debug_build_tcpdump_filter()
{
	local tok list item
	local tcp_ports=""
	local udp_ports=""
	local tcp_expr=""
	local udp_expr=""
	local filter=""

	# Collect all TCP/UDP filter ports from every NFQWS2 profile (--new separated).
	for tok in $NFQWS2_OPT; do
		case "$tok" in
			--filter-tcp=*)
				list="${tok#--filter-tcp=}"
				for item in $(echo "$list" | tr ',' ' '); do
					case "$item" in
						''|*[!0-9-]*)
							continue
							;;
					esac
					case " $tcp_ports " in
						*" $item "*) ;;
						*) tcp_ports="$tcp_ports $item" ;;
					esac
				done
				;;
			--filter-udp=*)
				list="${tok#--filter-udp=}"
				for item in $(echo "$list" | tr ',' ' '); do
					case "$item" in
						''|*[!0-9-]*)
							continue
							;;
					esac
					case " $udp_ports " in
						*" $item "*) ;;
						*) udp_ports="$udp_ports $item" ;;
					esac
				done
				;;
		esac
	done

	for item in $tcp_ports; do
		case "$item" in
			*-*)
				local first="${item%-*}"
				local last="${item#*-}"
				case "$first$last" in
					''|*[!0-9]*)
						continue
						;;
				esac
				[ -n "$tcp_expr" ] && tcp_expr="$tcp_expr or "
				tcp_expr="${tcp_expr}portrange $first-$last"
				;;
			*)
				[ -n "$tcp_expr" ] && tcp_expr="$tcp_expr or "
				tcp_expr="${tcp_expr}port $item"
				;;
		esac
	done

	for item in $udp_ports; do
		case "$item" in
			*-*)
				local first="${item%-*}"
				local last="${item#*-}"
				case "$first$last" in
					''|*[!0-9]*)
						continue
						;;
				esac
				[ -n "$udp_expr" ] && udp_expr="$udp_expr or "
				udp_expr="${udp_expr}portrange $first-$last"
				;;
			*)
				[ -n "$udp_expr" ] && udp_expr="$udp_expr or "
				udp_expr="${udp_expr}port $item"
				;;
		esac
	done

	[ -n "$tcp_expr" ] && filter="(tcp and ($tcp_expr))"
	if [ -n "$udp_expr" ]; then
		[ -n "$filter" ] && filter="$filter or "
		filter="${filter}(udp and ($udp_expr))"
	fi

	if [ -z "$filter" ]; then
		filter='(tcp and (port 80 or port 443 or port 2053 or port 2083 or port 2087 or port 2096 or port 8443)) or (udp and port 443)'
	fi

	echo "$filter"
}

traffic_debug_tcpdump_start()
{
	[ "$Z2K_TRAFFIC_DEBUG" = "1" ] || return 0

	exists tcpdump || {
		echo "WARN: traffic debug enabled, but tcpdump not found; skipping pcap capture"
		return 0
	}

	# Stop previous tcpdump if pidfile exists (stale or running).
	traffic_debug_tcpdump_stop

	local pcap="$Z2K_TRAFFIC_DEBUG_BASE/traffic.pcap"
	local err="$Z2K_TRAFFIC_DEBUG_BASE/tcpdump.err.log"
	local filter
	filter="$(traffic_debug_build_tcpdump_filter)"

	# Rotate by size to avoid filling storage: 10 files x 5MB = ~50MB max.
	# NOTE: if tcpdump doesn't support -C/-W, it will fail; see tcpdump.err.log.
	tcpdump -i any -nn -s 0 -U -w "$pcap" -C 5 -W 10 "$filter" >/dev/null 2>>"$err" &
	local pid=$!
	echo "$pid" > "$Z2K_TRAFFIC_DEBUG_PIDFILE"
	chmod 666 "$Z2K_TRAFFIC_DEBUG_PIDFILE" 2>/dev/null || true
	echo "traffic debug: tcpdump filter: $filter"
	echo "traffic debug: tcpdump started (PID $pid)"
}

traffic_debug_tcpdump_stop()
{
	local pidfile="${Z2K_TRAFFIC_DEBUG_PIDFILE:-${EXTRA_STRATS_DIR:-$ZAPRET_BASE/extra_strats}/cache/traffic/tcpdump.pid}"
	[ -f "$pidfile" ] || return 0

	local pid
	pid="$(cat "$pidfile" 2>/dev/null)"
	if [ -n "$pid" ] && kill -0 "$pid" 2>/dev/null; then
		echo "traffic debug: stopping tcpdump (PID $pid)"
		kill "$pid" 2>/dev/null || true
		sleep 1
		kill -0 "$pid" 2>/dev/null && kill -9 "$pid" 2>/dev/null || true
	fi
	rm -f "$pidfile" 2>/dev/null || true
}
