PIDDIR=/var/run
USEROPT=""
[ -n "$WS_USER" ] && USEROPT="--user=$WS_USER"
NFQWS2="${NFQWS2:-$ZAPRET_BASE/nfq2/nfqws2}"
LUA_LIB="$ZAPRET_BASE/lua/zapret-lib.lua"
[ -f "$LUA_LIB" ] || LUA_LIB="$LUA_LIB.gz"
LUA_ANTIDPI="$ZAPRET_BASE/lua/zapret-antidpi.lua"
[ -f "$LUA_ANTIDPI" ] || LUA_ANTIDPI="$LUA_ANTIDPI.gz"
LUAOPT="--lua-init=@$LUA_LIB --lua-init=@$LUA_ANTIDPI"
LUA_AUTO="$ZAPRET_BASE/lua/zapret-auto.lua"
[ -f "$LUA_AUTO" ] || LUA_AUTO="$LUA_AUTO.gz"
[ -f "$LUA_AUTO" ] && LUAOPT="$LUAOPT --lua-init=@$LUA_AUTO"
LUA_LOCKED="$ZAPRET_BASE/lua/locked.lua"
[ -f "$LUA_LOCKED" ] && LUAOPT="$LUAOPT --lua-init=@$LUA_LOCKED"
LUA_Z2K_AUTOCIRCULAR="$ZAPRET_BASE/lua/z2k-autocircular.lua"
[ -f "$LUA_Z2K_AUTOCIRCULAR" ] && LUAOPT="$LUAOPT --lua-init=@$LUA_Z2K_AUTOCIRCULAR"
LUA_Z2K_MODERN_CORE="$ZAPRET_BASE/lua/z2k-modern-core.lua"
[ -f "$LUA_Z2K_MODERN_CORE" ] && LUAOPT="$LUAOPT --lua-init=@$LUA_Z2K_MODERN_CORE"
NFQWS2_OPT_BASE="$USEROPT --fwmark=$DESYNC_MARK $LUAOPT"

# Load custom TLS ClientHello blob for strategies (manual: --blob is engine init option).
TLS_MAX_RU_BLOB="$ZAPRET_BASE/files/fake/tls_clienthello_max_ru.bin"
[ -s "$TLS_MAX_RU_BLOB" ] && NFQWS2_OPT_BASE="$NFQWS2_OPT_BASE --blob=tls_max_ru:@$TLS_MAX_RU_BLOB"

TLS_14_BLOB="$ZAPRET_BASE/files/fake/tls_clienthello_14.bin"
[ -s "$TLS_14_BLOB" ] && NFQWS2_OPT_BASE="$NFQWS2_OPT_BASE --blob=tls_clienthello_14:@$TLS_14_BLOB"

TLS_GOOGLE_BLOB="$ZAPRET_BASE/files/fake/tls_clienthello_www_google_com.bin"
[ -s "$TLS_GOOGLE_BLOB" ] && NFQWS2_OPT_BASE="$NFQWS2_OPT_BASE --blob=tls_clienthello_www_google_com:@$TLS_GOOGLE_BLOB"

TLS_STUN_BLOB="$ZAPRET_BASE/files/fake/stun.bin"
[ -s "$TLS_STUN_BLOB" ] && NFQWS2_OPT_BASE="$NFQWS2_OPT_BASE --blob=stun:@$TLS_STUN_BLOB"

TLS_4PDA_BLOB="$ZAPRET_BASE/files/fake/tls_clienthello_4pda_to.bin"
[ -s "$TLS_4PDA_BLOB" ] && NFQWS2_OPT_BASE="$NFQWS2_OPT_BASE --blob=tls_clienthello_4pda_to:@$TLS_4PDA_BLOB"

TLS_VK_BLOB="$ZAPRET_BASE/files/fake/tls_clienthello_vk_com.bin"
[ -s "$TLS_VK_BLOB" ] && NFQWS2_OPT_BASE="$NFQWS2_OPT_BASE --blob=tls_clienthello_vk_com:@$TLS_VK_BLOB"

TLS_GOSUSLUGI_BLOB="$ZAPRET_BASE/files/fake/tls_clienthello_gosuslugi_ru.bin"
[ -s "$TLS_GOSUSLUGI_BLOB" ] && NFQWS2_OPT_BASE="$NFQWS2_OPT_BASE --blob=tls_clienthello_gosuslugi_ru:@$TLS_GOSUSLUGI_BLOB"

TLS_ACTIVATED_BLOB="$ZAPRET_BASE/files/fake/tls_clienthello_activated.bin"
[ -s "$TLS_ACTIVATED_BLOB" ] && NFQWS2_OPT_BASE="$NFQWS2_OPT_BASE --blob=tls_clienthello_activated:@$TLS_ACTIVATED_BLOB"

SYN_PACKET_BLOB="$ZAPRET_BASE/files/fake/syn_packet.bin"
[ -s "$SYN_PACKET_BLOB" ] && NFQWS2_OPT_BASE="$NFQWS2_OPT_BASE --blob=syn_packet:@$SYN_PACKET_BLOB"

QUIC_GOOGLE_BLOB="$ZAPRET_BASE/files/fake/quic_initial_www_google_com.bin"
[ -s "$QUIC_GOOGLE_BLOB" ] && NFQWS2_OPT_BASE="$NFQWS2_OPT_BASE --blob=quic_google:@$QUIC_GOOGLE_BLOB"

QUIC5_BLOB="$ZAPRET_BASE/files/fake/quic_5.bin"
[ -s "$QUIC5_BLOB" ] && NFQWS2_OPT_BASE="$NFQWS2_OPT_BASE --blob=quic5:@$QUIC5_BLOB"

QUIC4_BLOB="$ZAPRET_BASE/files/fake/quic_4.bin"
[ -s "$QUIC4_BLOB" ] && NFQWS2_OPT_BASE="$NFQWS2_OPT_BASE --blob=quic4:@$QUIC4_BLOB"

QUIC6_BLOB="$ZAPRET_BASE/files/fake/quic_6.bin"
[ -s "$QUIC6_BLOB" ] && NFQWS2_OPT_BASE="$NFQWS2_OPT_BASE --blob=quic6:@$QUIC6_BLOB"

QUIC1_BLOB="$ZAPRET_BASE/files/fake/quic_1.bin"
[ -s "$QUIC1_BLOB" ] && NFQWS2_OPT_BASE="$NFQWS2_OPT_BASE --blob=quic1:@$QUIC1_BLOB"

QUIC_TEST_BLOB="$ZAPRET_BASE/files/fake/quic_test_00.bin"
[ -s "$QUIC_TEST_BLOB" ] && NFQWS2_OPT_BASE="$NFQWS2_OPT_BASE --blob=quic_test:@$QUIC_TEST_BLOB"

TLS_ONETRUST_BLOB="$ZAPRET_BASE/files/fake/tls_clienthello_www_onetrust_com.bin"
[ -s "$TLS_ONETRUST_BLOB" ] && NFQWS2_OPT_BASE="$NFQWS2_OPT_BASE --blob=tls_clienthello_www_onetrust_com:@$TLS_ONETRUST_BLOB"

TLS_T2_BLOB="$ZAPRET_BASE/files/fake/t2.bin"
[ -s "$TLS_T2_BLOB" ] && NFQWS2_OPT_BASE="$NFQWS2_OPT_BASE --blob=t2:@$TLS_T2_BLOB"

TLS_4PDA_SHORT_BLOB="$ZAPRET_BASE/files/fake/4pda.bin"
[ -s "$TLS_4PDA_SHORT_BLOB" ] && NFQWS2_OPT_BASE="$NFQWS2_OPT_BASE --blob=4pda:@$TLS_4PDA_SHORT_BLOB"

HTTP_IANA_BLOB="$ZAPRET_BASE/files/fake/http_iana_org.bin"
[ -s "$HTTP_IANA_BLOB" ] && NFQWS2_OPT_BASE="$NFQWS2_OPT_BASE --blob=http_iana:@$HTTP_IANA_BLOB"

LISTS_DIR="$ZAPRET_BASE/lists"
EXTRA_STRATS_DIR="$ZAPRET_BASE/extra_strats"
CONFIG_DIR="/opt/etc/zapret2"
CUSTOM_DIR="${CUSTOM_DIR:-$ZAPRET_RW/init.d/keenetic}"
ORCH_SCRIPT="$EXTRA_STRATS_DIR/cache/orchestra/orchestrator.sh"
IPSET_CR="$ZAPRET_BASE/ipset/create_ipset.sh"

# ==============================================================================
# ������� ��� ������ � IPSET
# ==============================================================================

create_ipset()
{
	echo "Creating ip list table (firewall type $FWTYPE)"
	"$IPSET_CR" "$@"
}

# ==============================================================================
# KEENETIC FIREWALL FUNCTIONS (������ OpenWrt network.sh ������������)
# ==============================================================================

get_default_ifaces4()
{
	exists ip || return 0
	ip route show default 2>/dev/null | awk '{for (i=1;i<=NF;i++) if ($i=="dev") print $(i+1)}' | xargs
}

get_default_ifaces6()
{
	exists ip || return 0
	ip -6 route show default 2>/dev/null | awk '{for (i=1;i<=NF;i++) if ($i=="dev") print $(i+1)}' | xargs
}

get_wan_ifaces4()
{
	local ifaces
	if [ -n "$WAN_IFACE" ]; then
		ifaces="$(echo "$WAN_IFACE" | tr ',' ' ')"
	else
		ifaces="$(get_default_ifaces4)"
	fi
	ifaces="$(echo "$ifaces" | xargs)"
	if [ -n "$ifaces" ] && exists ip; then
		local i
		for i in $ifaces; do
			ip link show "$i" >/dev/null 2>&1 || echo "WARN: WAN iface '$i' not found"
		done
	fi
	[ -n "$ifaces" ] && unique $ifaces || true
}

get_wan_ifaces6()
{
	local ifaces
	if [ -n "$WAN_IFACE" ]; then
		ifaces="$(echo "$WAN_IFACE" | tr ',' ' ')"
	else
		ifaces="$(get_default_ifaces6)"
	fi
	ifaces="$(echo "$ifaces" | xargs)"
	if [ -n "$ifaces" ] && exists ip; then
		local i
		for i in $ifaces; do
			ip link show "$i" >/dev/null 2>&1 || echo "WARN: WAN iface '$i' not found"
		done
	fi
	[ -n "$ifaces" ] && unique $ifaces || true
}

# Keenetic-specific: ���������� ������ fw_nfqws_post4/post6/pre4/pre6
# � ������� �� OpenWrt, �� ������� network.sh � ����������� WAN �����������
# �������� ���������� WAN �� default route

fw_nfqws_post4()
{
	# $1 - 1 - add, 0 - del
	# $2 - filter
	# $3 - queue number
	local wan
	wan="$(get_wan_ifaces4)"
	if [ -n "$wan" ]; then
		_fw_nfqws_post4 "$1" "$2" "$3" "$wan"
	else
		echo "WARN: WAN iface not found (IPv4), skip applying nfqws rules"
		return 0
	fi
}

fw_nfqws_post6()
{
	# $1 - 1 - add, 0 - del
	# $2 - filter
	# $3 - queue number
	[ "$DISABLE_IPV6" = "1" ] && return 0
	local wan
	wan="$(get_wan_ifaces6)"
	if [ -n "$wan" ]; then
		_fw_nfqws_post6 "$1" "$2" "$3" "$wan"
	else
		echo "WARN: WAN iface not found (IPv6), skip applying nfqws rules"
		return 0
	fi
}

fw_nfqws_pre4()
{
	# $1 - 1 - add, 0 - del
	# $2 - filter
	# $3 - queue number
	local wan
	wan="$(get_wan_ifaces4)"
	if [ -n "$wan" ]; then
		_fw_nfqws_pre4 "$1" "$2" "$3" "$wan"
	else
		echo "WARN: WAN iface not found (IPv4), skip applying nfqws rules"
		return 0
	fi
}

fw_nfqws_pre6()
{
	# $1 - 1 - add, 0 - del
	# $2 - filter
	# $3 - queue number
	[ "$DISABLE_IPV6" = "1" ] && return 0
	local wan
	wan="$(get_wan_ifaces6)"
	if [ -n "$wan" ]; then
		_fw_nfqws_pre6 "$1" "$2" "$3" "$wan"
	else
		echo "WARN: WAN iface not found (IPv6), skip applying nfqws rules"
		return 0
	fi
}

# ==============================================================================
# ������� ���������� DAEMON (������������ ��� KEENETIC ��� PROCD)
# ==============================================================================

run_daemon()
{
    # $1 - daemon ID
    # $2 - daemon binary
    # $3 - daemon args
    local DAEMONBASE="$(basename "$2")"
    local PIDFILE="$PIDDIR/${DAEMONBASE}_$1.pid"

    echo "Starting daemon $1: $2 $3"

    # ������ � ���� � ����������� PID
    $2 $3 >/dev/null 2>&1 &
    local PID=$!

    # ��������� PID
    echo $PID > "$PIDFILE"

    # ��������� ��� ������� ����������
    sleep 1
    if kill -0 $PID 2>/dev/null; then
        echo "Daemon $1 started with PID $PID"
        return 0
    else
        echo "ERROR: Daemon $1 failed to start"
        rm -f "$PIDFILE"
        return 1
    fi
}

run_nfqws()
{
    # $1 - instance ID
    # $2 - nfqws options
    # No hostlist validation here — custom.d scripts (50-stun4all, 50-discord-media)
    # intentionally run without hostlists, relying on firewall rules (u32/nft @ih).
    # Hostlist checks happen at config generation time (add_hostlist_line in config_official.sh).
    run_daemon $1 "$NFQWS2" "$NFQWS2_OPT_BASE $2"
}

do_nfqws()
{
    # $1 - 0 (stop) or 1 (start)
    # $2 - instance ID
    # $3 - nfqws options
    [ "$1" = 0 ] || { shift; run_nfqws "$@"; }
}

stop_daemon_by_pidfile()
{
    # $1 - pidfile path
    if [ -f "$1" ]; then
        local PID=$(cat "$1")
        if [ -n "$PID" ] && kill -0 $PID 2>/dev/null; then
            echo "Stopping daemon with PID $PID"
            kill $PID 2>/dev/null
            sleep 1
            # Force kill ���� �� �����������
            kill -0 $PID 2>/dev/null && kill -9 $PID 2>/dev/null
        fi
        rm -f "$1"
    fi
}

stop_all_nfqws()
{
    echo "Stopping all nfqws daemons"

    # ���������� �� PID ������
    for pidfile in $PIDDIR/nfqws2_*.pid; do
        [ -f "$pidfile" ] && stop_daemon_by_pidfile "$pidfile"
    done

    # Fallback: killall ���� ���-�� ��������
    killall nfqws2 2>/dev/null

    # �������� ��� PID �����
    rm -f $PIDDIR/nfqws2_*.pid 2>/dev/null
}

# ==============================================================================
# ������� START/STOP DAEMONS
# ==============================================================================

start_daemons()
{
    echo "Starting zapret2 daemons"

    # ������������ ������� �� common/linux_daemons.sh
    # standard_mode_daemons �������� do_nfqws
    standard_mode_daemons 1

    # ��������� custom scripts ���� ����
    custom_runner zapret_custom_daemons 1

    return 0
}

stop_daemons()
{
    echo "Stopping zapret2 daemons"

    # ���������� ��� nfqws ��������
    stop_all_nfqws

    # ��������� custom scripts ��� ���������
    custom_runner zapret_custom_daemons 0

    return 0
}

restart_daemons()
{
    stop_daemons
    sleep 2
    start_daemons
}

# ==============================================================================
# ������� START/STOP FIREWALL
# ==============================================================================

load_modules()
{
    echo "Loading required kernel modules"

    # ������ ����������� ������� ��� ������ zapret2
    # Add connmark modules for Keenetic policy integration (nfqws2-keenetic style).
    local modules="xt_multiport xt_connbytes xt_NFQUEUE nfnetlink_queue xt_CONNMARK xt_connmark"

    for module in $modules; do
        if ! lsmod | grep -q "^$module"; then
            [ -n "$Z2K_DEBUG" ] && echo "DEBUG: Loading module: $module"
            modprobe "$module" 2>/dev/null || {
                echo "Warning: Failed to load module $module (may be built-in)"
            }
        else
            [ -n "$Z2K_DEBUG" ] && echo "DEBUG: Module already loaded: $module"
        fi
    done

    # ��������� ��������� ������ nfnetlink_queue
    if ! lsmod | grep -q "nfnetlink_queue" && ! modinfo nfnetlink_queue >/dev/null 2>&1; then
        echo "WARNING: nfnetlink_queue module not available!"
        echo "nfqws2 may fail with 'Operation not permitted'"
        return 1
    fi

    echo "Kernel modules loaded"
    return 0
}


# Keenetic fix (similar to nfqws2-keenetic): ensure UDP packets processed by nfqws2
# (marked with DESYNC_MARK) still get source NAT on WAN via a dedicated nat chain.
Z2K_IPT_NAT_CHAIN="zapret2_nat"

# Connmark-based exclusion (borrowed from nfqws2-keenetic):
# - Mark connections outside selected Keenetic policy (POLICY_NAME/POLICY_EXCLUDE) with CONNMARK exclude bit.
# - NFQUEUE rules include "-m connmark ! --mark $Z2K_CONNMARK_EXCLUDE" so excluded flows never enter NFQUEUE.
Z2K_CONNMARK_EXCLUDE="0x20000000/0x20000000"
Z2K_CONNMARK_OK4=0
Z2K_CONNMARK_OK6=0
Z2K_POLICY_MARK=""

iptablesw()
{
    # Prefer -w (xtables lock wait). Fallback without -w for older iptables.
    iptables -w "$@" 2>/dev/null || iptables "$@" 2>/dev/null
}

ip6tablesw()
{
    ip6tables -w "$@" 2>/dev/null || ip6tables "$@" 2>/dev/null
}

z2k_connmark_check_avail4()
{
    grep -qw connmark /proc/net/ip_tables_matches 2>/dev/null || return 1
    grep -qw CONNMARK /proc/net/ip_tables_targets 2>/dev/null || return 1
    return 0
}

z2k_connmark_check_avail6()
{
    grep -qw connmark /proc/net/ip6_tables_matches 2>/dev/null || return 1
    grep -qw CONNMARK /proc/net/ip6_tables_targets 2>/dev/null || return 1
    return 0
}

z2k_connmark_init()
{
    Z2K_CONNMARK_OK4=0
    Z2K_CONNMARK_OK6=0

    [ "$FWTYPE" = "iptables" ] || return 0

    # Try to load connmark modules (may be built-in).
    modprobe xt_CONNMARK 2>/dev/null || true
    modprobe xt_connmark 2>/dev/null || true

    exists iptables && z2k_connmark_check_avail4 && Z2K_CONNMARK_OK4=1
    [ "$DISABLE_IPV6" = "1" ] && return 0
    exists ip6tables && z2k_connmark_check_avail6 && Z2K_CONNMARK_OK6=1
}

z2k_detect_policy_mark()
{
    Z2K_POLICY_MARK=""

    # Default to nfqws2-keenetic convention. If policy doesn't exist, we process all traffic.
    POLICY_NAME="${POLICY_NAME:-nfqws}"
    POLICY_EXCLUDE="${POLICY_EXCLUDE:-0}"

    # ndmc exists on Keenetic firmware (outside Entware). Use /bin/ndmc when present.
    local ndmc_bin="ndmc"
    [ -x /bin/ndmc ] && ndmc_bin="/bin/ndmc"
    command -v "$ndmc_bin" >/dev/null 2>&1 || return 1

    # Extract policy mark by description (handle quotes and "mark:" vs "mark =").
    local mark
    mark="$("$ndmc_bin" -c "show ip policy" 2>/dev/null | awk -v name="$POLICY_NAME" '
        function trim(s) { sub(/^[ \t\r\n]+/, "", s); sub(/[ \t\r\n]+$/, "", s); return s }
        function unquote(s) {
            s=trim(s)
            if (s ~ /^\".*\"$/) { sub(/^\"/, "", s); sub(/\"$/, "", s) }
            return s
        }
        function rm_trailing_colon(s) { sub(/:+$/, "", s); return s }
        BEGIN { found=0; want=rm_trailing_colon(tolower(name)) }
        {
            line=tolower($0)
            if (line ~ /description[ \t]*=/) {
                desc=$0
                sub(/.*description[ \t]*=[ \t]*/, "", desc)
                desc=rm_trailing_colon(tolower(unquote(desc)))
                found = (desc == want) ? 1 : 0
                next
            }
            if (found && line ~ /mark[ \t]*[:=]/) {
                m=$0
                sub(/.*mark[ \t]*[:=][ \t]*/, "", m)
                m=unquote(m)
                split(m, a, /[ \t\r\n]+/)
                print a[1]
                exit
            }
        }
    ')"

    mark="${mark%%/*}"
    mark="${mark%%;*}"
    mark="${mark#0x}"
    mark="${mark#0X}"
    case "$mark" in
        ""|*[!0-9a-fA-F]*)
            return 1
            ;;
    esac

    Z2K_POLICY_MARK="0x${mark}/0x0fffffff"
    return 0
}

z2k_policy_connmark_start()
{
    [ "$FWTYPE" = "iptables" ] || return 0
    [ "$Z2K_CONNMARK_OK4" = "1" ] || return 0

    z2k_detect_policy_mark || return 0

    local pol_rule=""
    if [ "$POLICY_EXCLUDE" = "1" ]; then
        echo "Found policy '$POLICY_NAME'. Traffic from it will be excluded from processing."
        pol_rule="-m mark --mark $Z2K_POLICY_MARK -j CONNMARK --set-xmark $Z2K_CONNMARK_EXCLUDE"
    else
        echo "Found policy '$POLICY_NAME'. Only traffic from it will be processed."
        pol_rule="-m mark ! --mark $Z2K_POLICY_MARK -j CONNMARK --set-xmark $Z2K_CONNMARK_EXCLUDE"
    fi

    local wan iface
    wan="$(get_wan_ifaces4)"
    [ -n "$wan" ] || return 0

    for iface in $wan; do
        # Exclude connections outside policy by setting CONNMARK bit before NFQUEUE rules.
        iptablesw -t mangle -C POSTROUTING -o "$iface" $pol_rule || iptablesw -t mangle -I POSTROUTING -o "$iface" $pol_rule
    done

    [ "$Z2K_CONNMARK_OK6" = "1" ] || return 0

    wan="$(get_wan_ifaces6)"
    [ -n "$wan" ] || return 0

    for iface in $wan; do
        ip6tablesw -t mangle -C POSTROUTING -o "$iface" $pol_rule || ip6tablesw -t mangle -I POSTROUTING -o "$iface" $pol_rule
    done
}

z2k_policy_connmark_stop()
{
    [ "$FWTYPE" = "iptables" ] || return 0
    [ "$Z2K_CONNMARK_OK4" = "1" ] || return 0

    z2k_detect_policy_mark || return 0

    local pol_rule=""
    if [ "$POLICY_EXCLUDE" = "1" ]; then
        pol_rule="-m mark --mark $Z2K_POLICY_MARK -j CONNMARK --set-xmark $Z2K_CONNMARK_EXCLUDE"
    else
        pol_rule="-m mark ! --mark $Z2K_POLICY_MARK -j CONNMARK --set-xmark $Z2K_CONNMARK_EXCLUDE"
    fi

    local wan iface
    wan="$(get_wan_ifaces4)"
    [ -n "$wan" ] || return 0

    for iface in $wan; do
        while iptablesw -t mangle -C POSTROUTING -o "$iface" $pol_rule 2>/dev/null; do
            iptablesw -t mangle -D POSTROUTING -o "$iface" $pol_rule || break
        done
    done

    [ "$Z2K_CONNMARK_OK6" = "1" ] || return 0

    wan="$(get_wan_ifaces6)"
    [ -n "$wan" ] || return 0

    for iface in $wan; do
        while ip6tablesw -t mangle -C POSTROUTING -o "$iface" $pol_rule 2>/dev/null; do
            ip6tablesw -t mangle -D POSTROUTING -o "$iface" $pol_rule || break
        done
    done
}

# Override zapret2 iptables NFQUEUE rule builders to respect connmark exclusion.
# This keeps rule semantics identical to upstream, adding only "-m connmark ! --mark $Z2K_CONNMARK_EXCLUDE".
_fw_nfqws_post4()
{
    # $1 - 1 - add, 0 - del
    # $2 - iptable filter for ipv4
    # $3 - queue number
    # $4 - wan interface names space separated
    [ "$DISABLE_IPV4" = "1" -o -z "$2" ] || {
        local i rule connchk=""

        ipt_print_op $1 "$2" "nfqws postrouting (qnum $3)"

        [ "$Z2K_CONNMARK_OK4" = "1" ] && connchk="-m connmark ! --mark $Z2K_CONNMARK_EXCLUDE"

        rule="$(ipt_mark_filter) $connchk -m mark ! --mark $DESYNC_MARK/$DESYNC_MARK $2 $IPSET_EXCLUDE dst -j NFQUEUE --queue-num $3 --queue-bypass"
        if [ -n "$4" ] ; then
            for i in $4; do
                ipt_add_del $1 POSTROUTING -t mangle -o $i $rule
            done
        else
            ipt_add_del $1 POSTROUTING -t mangle $rule
        fi
    }
}

_fw_nfqws_post6()
{
    # $1 - 1 - add, 0 - del
    # $2 - iptable filter for ipv6
    # $3 - queue number
    # $4 - wan interface names space separated
    [ "$DISABLE_IPV6" = "1" -o -z "$2" ] || {
        local i rule connchk=""

        ipt_print_op $1 "$2" "nfqws postrouting (qnum $3)" 6

        [ "$Z2K_CONNMARK_OK6" = "1" ] && connchk="-m connmark ! --mark $Z2K_CONNMARK_EXCLUDE"

        rule="$(ipt_mark_filter) $connchk -m mark ! --mark $DESYNC_MARK/$DESYNC_MARK $2 $IPSET_EXCLUDE6 dst -j NFQUEUE --queue-num $3 --queue-bypass"
        if [ -n "$4" ] ; then
            for i in $4; do
                ipt6_add_del $1 POSTROUTING -t mangle -o $i $rule
            done
        else
            ipt6_add_del $1 POSTROUTING -t mangle $rule
        fi
    }
}

_fw_nfqws_pre4()
{
    # $1 - 1 - add, 0 - del
    # $2 - iptable filter for ipv4
    # $3 - queue number
    # $4 - wan interface names space separated
    [ "$DISABLE_IPV4" = "1" -o -z "$2" ] || {
        local i rule connchk=""

        ipt_print_op $1 "$2" "nfqws input+forward (qnum $3)"

        [ "$Z2K_CONNMARK_OK4" = "1" ] && connchk="-m connmark ! --mark $Z2K_CONNMARK_EXCLUDE"

        rule="$connchk $2 $IPSET_EXCLUDE src -j NFQUEUE --queue-num $3 --queue-bypass"
        if [ -n "$4" ] ; then
            for i in $4; do
                # iptables PREROUTING chain is before NAT. not possible to have DNATed ip's there
                ipt_add_del $1 INPUT -t mangle -i $i $rule
                ipt_add_del $1 FORWARD -t mangle -i $i $rule
            done
        else
            ipt_add_del $1 INPUT -t mangle $rule
            ipt_add_del $1 FORWARD -t mangle $rule
        fi
    }
}

_fw_nfqws_pre6()
{
    # $1 - 1 - add, 0 - del
    # $2 - iptable filter for ipv6
    # $3 - queue number
    # $4 - wan interface names space separated
    [ "$DISABLE_IPV6" = "1" -o -z "$2" ] || {
        local i rule connchk=""

        ipt_print_op $1 "$2" "nfqws input+forward (qnum $3)" 6

        [ "$Z2K_CONNMARK_OK6" = "1" ] && connchk="-m connmark ! --mark $Z2K_CONNMARK_EXCLUDE"

        rule="$connchk $2 $IPSET_EXCLUDE6 src -j NFQUEUE --queue-num $3 --queue-bypass"
        if [ -n "$4" ] ; then
            for i in $4; do
                # iptables PREROUTING chain is before NAT. not possible to have DNATed ip's there
                ipt6_add_del $1 INPUT -t mangle -i $i $rule
                ipt6_add_del $1 FORWARD -t mangle -i $i $rule
            done
        else
            ipt6_add_del $1 INPUT -t mangle $rule
            ipt6_add_del $1 FORWARD -t mangle $rule
        fi
    }
}

z2k_udp_masquerade_fix_start()
{
    [ "$FWTYPE" = "iptables" ] || return 0
    exists iptables || return 0

    local wan iface
    wan="$(get_wan_ifaces4)"
    [ -n "$wan" ] || {
        [ -n "$Z2K_DEBUG" ] && echo "DEBUG: UDP masquerade fix: WAN iface not found, skip"
        return 0
    }

    local mark="${DESYNC_MARK:-0x40000000}"
    local mark_processed="${mark}/${mark}"

    iptablesw -t nat -N "$Z2K_IPT_NAT_CHAIN"
    iptablesw -t nat -F "$Z2K_IPT_NAT_CHAIN"
    iptablesw -t nat -C POSTROUTING -j "$Z2K_IPT_NAT_CHAIN" || iptablesw -t nat -A POSTROUTING -j "$Z2K_IPT_NAT_CHAIN"

    for iface in $wan; do
        iptablesw -t nat -A "$Z2K_IPT_NAT_CHAIN" -o "$iface" -m mark --mark "$mark_processed" -p udp -j MASQUERADE
    done
}

z2k_udp_masquerade_fix_stop()
{
    [ "$FWTYPE" = "iptables" ] || return 0
    exists iptables || return 0

    while iptablesw -t nat -C POSTROUTING -j "$Z2K_IPT_NAT_CHAIN" 2>/dev/null; do
        iptablesw -t nat -D POSTROUTING -j "$Z2K_IPT_NAT_CHAIN" || break
    done

    iptablesw -t nat -F "$Z2K_IPT_NAT_CHAIN"
    iptablesw -t nat -X "$Z2K_IPT_NAT_CHAIN"
}
start_fw()
{
    echo "Applying zapret2 firewall rules"

    # DEBUG: ��������� FWTYPE ����� linux_fwtype
    [ -n "$Z2K_DEBUG" ] && echo "DEBUG: � start_fw() ����� linux_fwtype - FWTYPE='$FWTYPE'"

    # ���������� ��� firewall (iptables/nftables)
    linux_fwtype

    # DEBUG: ��������� FWTYPE ����� linux_fwtype
    [ -n "$Z2K_DEBUG" ] && echo "DEBUG: � start_fw() ����� linux_fwtype - FWTYPE='$FWTYPE'"

    echo "Detected firewall type: $FWTYPE"

    # ������������ ����������� ������� �� common/linux_fw.sh
    z2k_connmark_init
    zapret_apply_firewall
    z2k_policy_connmark_start
    z2k_udp_masquerade_fix_start

    return 0
}

stop_fw()
{
    echo "Removing zapret2 firewall rules"

    # ���������� ��� firewall
    linux_fwtype

    # ������������ ����������� �������
    z2k_connmark_init
    z2k_udp_masquerade_fix_stop
    z2k_policy_connmark_stop
    zapret_unapply_firewall

    return 0
}

restart_fw()
{
    stop_fw
    sleep 1
    start_fw
}

# ==============================================================================
# OPTIONAL NFTABLES HELPERS (IF AVAILABLE)
# ==============================================================================

reload_ifsets()
{
    existf zapret_reload_ifsets || {
        echo "reload_ifsets not available (nftables functions not loaded)"
        return 1
    }
    zapret_reload_ifsets
}

list_ifsets()
{
    existf zapret_list_ifsets || {
        echo "list_ifsets not available (nftables functions not loaded)"
        return 1
    }
    zapret_list_ifsets
}

list_table()
{
    existf zapret_list_table || {
        echo "list_table not available (nftables functions not loaded)"
        return 1
    }
    zapret_list_table
}

# ==============================================================================
# �������� ������� START/STOP/RESTART
# ==============================================================================

start()
{
    if [ "$ENABLED" != "1" ]; then
        echo "zapret2 is disabled in config"
        return 1
    fi

    echo "Starting zapret2 service"

    # 1. ��������� ����������� ������ ����
    load_modules || echo "Warning: Some modules failed to load"

    # 2. ��������� firewall �������
    [ "$INIT_APPLY_FW" = "1" ] && start_fw

    # 2.1. ����������� autohostlist ����� (���� ��������)
    ensure_autohostlist_files
    sync_autohostlist_to_rkn

    # 2.2. ����������� autocircular cache/debug files (writable by runtime user)
    ensure_autocircular_files

    # traffic debug (optional): nfqws2 debug log + tcpdump pcap capture
    ensure_traffic_debug_files
    traffic_debug_prepare
    traffic_debug_enable_nfqws2_log
    traffic_debug_tcpdump_start

    # 3. ��������� daemon ��������
    start_daemons

    # 4. ��������� orchestrator (circular_locked rotation)
    [ -x "$ORCH_SCRIPT" ] && "$ORCH_SCRIPT" start

    echo "zapret2 service started"
    return 0
}

stop()
{
    echo "Stopping zapret2 service"

    traffic_debug_tcpdump_stop
    # 0. ���������� orchestrator
    [ -x "$ORCH_SCRIPT" ] && "$ORCH_SCRIPT" stop

    # 1. ���������� daemon ��������
    stop_daemons

    # Sync auto-detected domains after runtime updates.
    sync_autohostlist_to_rkn

    # 2. ������� firewall �������
    [ "$INIT_APPLY_FW" = "1" ] && stop_fw

    echo "zapret2 service stopped"
    return 0
}

restart()
{
    stop
    sleep 2
    start
}

status()
{
    echo "Checking zapret2 status..."

    # ��������� �������� �� PID ������
    local running=0
    for pidfile in $PIDDIR/nfqws2_*.pid; do
        if [ -f "$pidfile" ]; then
            local PID=$(cat "$pidfile")
            if kill -0 $PID 2>/dev/null; then
                echo "nfqws2 daemon running (PID $PID)"
                running=$((running + 1))
            else
                echo "Stale PID file: $pidfile"
            fi
        fi
    done

    if [ $running -gt 0 ]; then
        echo "zapret2 is running ($running daemons)"

        # �������� ��������
        echo "Processes:"
        pgrep -af nfqws2

        return 0
    else
        echo "zapret2 is not running"
        return 1
    fi
}

# ==============================================================================
# MAIN
# ==============================================================================

case "$1" in
    start)
        start
        ;;
    stop)
        stop
        ;;
    restart)
        restart
        ;;
    status)
        status
        ;;
    start_fw)
        start_fw
        ;;
    stop_fw)
        stop_fw
        ;;
    restart_fw)
        restart_fw
        ;;
    start_daemons)
        start_daemons
        ;;
    stop_daemons)
        stop_daemons
        ;;
    restart_daemons)
        restart_daemons
        ;;
    reload_ifsets)
        reload_ifsets
        ;;
    list_ifsets)
        list_ifsets
        ;;
    list_table)
        list_table
        ;;
    *)
        echo "Usage: $0 {start|stop|restart|status|start_fw|stop_fw|restart_fw|start_daemons|stop_daemons|restart_daemons|reload_ifsets|list_ifsets|list_table}"
        exit 1
        ;;
esac

exit $?
